#>plan_d
#:layer #!pragmatics

^meta{
  source: "PLAN.D.md"
  dialect: spw_native
  style: phase_block_titles
}

&plan_contracts{
  preserve_phase_total: true
  preserve_houdini_track: true
  preserve_firefox_track: true
  use_phase_blocks: true
}

?["plan_d_integrity_gate"]{
  require: phases_defined_in_blocks
  require: houdini_phase_total_52
  require: firefox_phase_total_13
  require: phase_total_65
  on_fail: emit_partition_repair_packet
}

!probe{
  id: plan_d.phase_block_probe
  ask: all_tracks_expressed_via_phase_title_blocks
}

^context{
  baseline_date: "March 2, 2026"
  mode: exploration_and_audit_only
}

&sources{
  houdini_mdn: "https://developer.mozilla.org/en-US/docs/Web/API/Houdini_APIs"
  firefox_features_mdn: "https://developer.mozilla.org/en-US/docs/Mozilla/Firefox/Experimental_features"
}

^output_contract{
  phase_packet_shape: { intent: required, audit: required, evidence: required, recommendation: required }
  artifacts: spw_only
}

^phases["Houdini APIs Exploration"]{
  ^phase["Scope Constraints"]{
    slug: scope_constraints
    task: define_scope_nongoals_risk_tolerance
    ={ "book/audits/houdini/01-scope_constraints.spw" }
  }

  ^phase["Support Matrix"]{
    slug: support_matrix
