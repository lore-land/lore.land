{
  "name": "lore.land",
  "version": "1.0.0",
  "type": "module",
  "description": "A worldbuilding monument: seeded chapters, inspectable craft, and a living serial.",
  "scripts": {
    "predev": "npm run chapters:build",
    "dev": "vite",
    "chapters:build": "node book/scripts/tools/build-chapters.mjs",
    "spw:export": "node .spw/tools/export-chapters.mjs",
    "spw:project": "node .spw/tools/project-public-spw.mjs",
    "spw:verify": "node .spw/tools/project-public-spw.mjs --verify",
    "dist:static": "node book/scripts/tools/project-dist-static.mjs",
    "dist:verify": "node book/scripts/tools/project-dist-static.mjs --verify && npm run spw:verify",
    "build": "npm run chapters:build && npm run spw:export && vite build && npm run spw:project && npm run dist:static",
    "preview": "vite preview",
    "font": "node book/scripts/tools/font/build.mjs",
    "assets:optimize": "node book/scripts/tools/assets/optimize-assets.mjs",
    "assets:optimize:dry": "node book/scripts/tools/assets/optimize-assets.mjs --dry-run",
    "spw:probes": "node .spw/tools/alignment-probes.mjs",
    "spw:plates": "node .spw/tools/plates-manifest.mjs",
    "spw:lint": "tsx .spw/tools/spw-lint.mjs"
  },
  "keywords": [],
  "author": "Sam Washington",
  "license": "ISC",
  "devDependencies": {
    "opentype.js": "^1.3.4",
    "tsx": "^4.23.1",
    "vite": "^7.3.1"
  }
}
