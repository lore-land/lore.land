    route: ^[chapter/07/s04]{open}
  ]
  s05: {
    handle: "section/05"
    type: "section"
    title: "The Shadow’s Reflection"
    excerpt: "The shadow twisted and turned, matching Boof’s steps but sometimes leading the way. It seemed to know the path Boof sought but refused to show the way forward. The boonberries above them dimmed, casting the world into..."
    route: ^[chapter/07/s05]{open}
  }
  s06: <
    handle: "custom-boof/06"
    type: "custom-boof"
    excerpt: "Boof reached out, hoping to touch the shadow, to understand it. \"Is this what the Fool wanted me to see?\" Boof wondered. The shadow flickered and danced, evading their grasp."
    route: ^[chapter/07/s06]{open}
  >
  s07: <
    handle: "custom-fool/07"
    type: "custom-fool"
    excerpt: "\"The shadow will always be with you, Boof,\" the Fool’s voice echoed from the darkness. \"But the real question is: whose shadow is it?\""
    route: ^[chapter/07/s07]{open}
  >
]

