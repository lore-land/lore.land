^[chapter/07/sections][
  s01: <
    handle: "custom-boof/01"
    type: "custom-boof"
    excerpt: "Deeper in the labyrinth, Boof stopped pretending the pursuit was one-sided. Something kept the same pace—a shadow , just beyond their reach."
    route: ^[chapter/07/s01]{open}
  >
  s02: <
    handle: "custom-shadow/02"
    type: "custom-shadow"
    excerpt: "The shadow stretched across the walls, mirroring Boof's every move, but distorted, as though it belonged to someone—or something—else entirely."
