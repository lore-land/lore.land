  s07: <
    handle: "custom-fool/07"
    type: "custom-fool"
    excerpt: "\"You’re ready, Boof. The journey ahead is yours, and it’s one that never truly ends. The Fool's laughter was soft now, almost like an old friend’s chuckle. 'The path is yours to create.'\""
    route: ^[chapter/12/s07]{open}
