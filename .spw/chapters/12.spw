  s05: {
    handle: "section/05"
    type: "section"
    title: "The Open Road"
    excerpt: "Boof looked down the path, feeling a calmness that hadn’t been there before. This was a different kind of journey—one without tricks or hidden challenges. The boonberries swayed gently in the trees, as if urging Boof ..."
    route: ^[chapter/12/s05]{open}
  }
  s06: <
    handle: "custom-boof/06"
    type: "custom-boof"
    excerpt: "\"Where does it lead?\" Boof asked aloud. The Fool didn’t answer, but Boof felt no frustration, only curiosity. It didn’t matter where the path led—it mattered that they were walking it."
    route: ^[chapter/12/s06]{open}
