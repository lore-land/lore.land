#>plan_c
#:layer #!pragmatics

~<rationale>{
  Plan C is a two-track exploration: (1) a deep audit of Shadow DOM applicability
  to the lore.land component model, and (2) a systematic sweep of Chrome stable
  milestones M94–M145 for shadow-DOM-relevant platform changes. Track 1 produces
  an adoption recommendation; Track 2 provides the evidentiary basis of browser
  support data that informs it.
}

^meta{
  source: "PLAN.C.md"
  dialect: spw_native
  style: phase_block_titles
  normative_voice: specification
  phase_count: 65
  tracks: { shadow_dom: 13, chrome_milestones: 52 }
}

&plan_contracts{
  preserve_phase_total: true
  preserve_shadow_track: true
  preserve_chrome_track: true
  use_phase_blocks: true
  #invariant: shadow_track_phases_are_domain_specific_not_templated
  #invariant: chrome_track_phases_emit_per_milestone_artifacts
}

?["plan_c_integrity_gate"]{
  require: phases_defined_in_blocks
  require: shadow_phase_total_13
  require: chrome_phase_total_52
  require: milestone_contiguity_M145_to_M94
  on_fail: emit_range_repair_packet
}

!probe{
  id: plan_c.phase_block_probe
  ask: all_tracks_expressed_via_phase_title_blocks
  !assert: deviation_count == 0
}

^verified_context{
  baseline_date: "March 2, 2026"
  latest_chrome_stable_major: 145
  chrome_145_stable_date: "February 10, 2026"
  platform_audit_refresh: "2026-07-16"
}

^audit_overlay_2026_07_16{
  source: ".spw/audits/platform-ship-audit-2026-07-16.spw"
  shadow_dom_lived: {
    chapter_sigils: "book/scripts/modules/chapter-sigil.mjs — open shadow roots with mirrored inspector styles"
    finding: "Shadow track is no longer purely speculative; inventory phase should treat sigils as intentional adoption"
    style_strategy: "document stylesheets cannot reach shadow; chapter-sigil embeds inspection CSS mirror of interactive.css"
  }
  chrome_platform_in_use: [
    "animation-timeline: view() for atmosphere parallax",
    ":has() for aside and section-head layout",
    "color-mix() throughout hub and rail",
    "import.meta.glob for chapter sigil modules (Vite)"
  ]
  prioritize_next_milestones: [
    "View Transitions API for chamber continuity (also platform.spw phase 09)",
    "Popover API / invokers for inspectors (optional vs shadow panels)",
    "content-visibility and container queries for long chambers"
  ]
  deprioritize_until_p0: [
    "broad closed-mode shadow migration of entire rail",
    "milestone catalog work that does not unblock SW/social/vite"
  ]
  refs: [".spw/surfaces/platform.spw", "PLAN.D.spw#audit_overlay_2026_07_16"]
}

^production_overlay_2026_07_16{
  source: ".spw/surfaces/atelier.spw"
  bearing: "milestone features are scored for wonder-per-seam-risk, not novelty — a signature moment that introduces an unaccounted seam costs more than it earns"
  couplings: [
    "View Transitions is the candidate chamber-crossing signature (atelier phase 05); its ledger exposure is temporal (tempo vs room) + geometric (shared-element seams) — both must probe clean before ship",
    "chapter-sigil style mirror is standing ledger entry AL-005 (intentional, watched) — §shadow-dom phase 02 encapsulation audit owns its retirement decision",
    "popover / anchor positioning serve inspector chrome for the craftsperson posture (ladder rungs operate/inspect); adopt only with fallback dignity in non-supporting engines"
  ]
  scoring_addendum: "milestone relevance scoring gains a wonder column: {seam_risk: geometric|temporal|none, degrade_quality: calm|degraded|broken}"
  refs: [".spw/state/alignment-ledger.spw#AL-005", ".spw/surfaces/atelier.spw#wonder_budget"]
}

&verified_sources{
  release_notes_145: "https://developer.chrome.com/release-notes/145"
  stable_promotion_145: "https://chromereleases.googleblog.com/2026/02/stable-channel-update-for-desktop_10.html"
  stable_patch_145: "https://chromereleases.googleblog.com/2026/02/stable-channel-update-for-desktop_13.html"
}

^output_contract{
  phase_packet_shape: { scope: required, findings: required, evidence: required, decision: required }
  canonical_artifacts: spw_only
  .note: "every shadow DOM phase produces a distinct artifact with domain-specific findings;
          every chrome milestone phase produces a uniform artifact scored for shadow DOM relevance"
}


^phases["Shadow DOM Exploration"]{
  .note: "13 phases — each addresses a distinct facet of the Shadow DOM specification
          as it relates to the existing lore.land component architecture"
  %track_invariant: each_phase_scope_is_unique

  ^phase["Shadow DOM Baseline Inventory"]{
    ^task{
      @scope: "inventory current shadow DOM usage across the codebase — distinguish intentional
               shadow roots from incidental usage (e.g., third-party web components, browser UA shadows)"
      @findings: "produce frequency table: {component, shadow_mode, slot_count, style_strategy}"
      @evidence: "cross-reference with DOM Spec §4.8 (shadow trees) and HTML Spec §4.13.6 (custom elements)"
      @decision: classify_adopt_monitor_reject
    }
    %metrics: {
      shadow_root_count: "total across all pages — informational"
      intentional_vs_incidental: "ratio — informs adoption scope"
    }
    ={ "book/audits/shadow-dom/01-inventory.spw" }
  }

  ^phase["Encapsulation Model Audit"]{
    ^task{
      @scope: "audit the boundary between component-internal DOM and public API surface —
               determine whether current [data-spw-component] depth model (0-3) requires
               encapsulation or whether attribute-based scoping is sufficient"
      @findings: "classify each component boundary as: hard (needs shadow), soft (attribute scoping adequate),
                  or porous (currently leaking styles/events across boundary)"
      @evidence: "DOM Spec §4.8.1 (open vs closed mode), CSS Scoping §3 (shadow host styling),
                  measured specificity conflicts from PLAN.A §foundation phase 01"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/02-encapsulation.spw" }
  }

  ^phase["Slotting and Composition Analysis"]{
    ^task{
      @scope: "evaluate slot-based content distribution against current composition patterns —
               lore.land uses nested [data-spw-component] elements; determine whether <slot>
               distribution improves or complicates the existing nesting model"
      @findings: "map current composition patterns to slot equivalents; identify cases where
                  slot flattening would change the effective DOM order (accessibility tree impact)"
      @evidence: "DOM Spec §4.8.4 (slot assignment), HTML Spec §4.13.6.2 (slotchange event),
                  measured nesting depths from PLAN.A §foundation phase 04"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/03-slotting.spw" }
  }

  ^phase["Styling Surface Audit"]{
    ^task{
      @scope: "audit the four shadow styling mechanisms — :host, ::slotted, ::part, exportparts —
               against the existing @layer + custom property theming system"
      @findings: "determine whether shadow styling mechanisms can interoperate with the
                  CSS layer stack (core/tokens.css, core/motifs.css) or require a parallel system;
                  measure the surface area of ::part exposure needed for theme variables"
      @evidence: "CSS Scoping §3.2 (:host), §4 (::slotted), CSS Shadow Parts §2 (::part),
                  CSS Cascading §6.1 (layer ordering with shadow boundaries)"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/04-styling-surface.spw" }
  }

  ^phase["Event Retargeting and Composed Path Audit"]{
    ^task{
      @scope: "audit event retargeting behavior for the interactive spw components —
               drag-to-scope, tooltip, brace-tracing all rely on event.target identity
               which shadow DOM retargeting would change"
      @findings: "enumerate all event.target and event.composedPath() usage sites;
                  classify each as: compatible (works with retargeting), breaking (requires
                  composedPath migration), or ambiguous (needs runtime testing)"
      @evidence: "DOM Spec §2.7 (retargeting algorithm), §2.9 (composed event path),
                  UI Events §5.4 (mouse event targets), spw-interactions.mjs event handlers"
      @decision: classify_adopt_monitor_reject
    }
    %metrics: {
      breaking_event_sites: "count — primary adoption cost indicator"
      composedPath_migration_effort: "lines of handler code requiring changes"
    }
    ={ "book/audits/shadow-dom/05-events.spw" }
  }

  ^phase["Focus and Keyboard Navigation Audit"]{
    ^task{
      @scope: "audit shadow DOM focus delegation model against current keyboard navigation —
               ebook-navigation.mjs uses bracket-hold for nav-shape switching; determine
               whether delegatesFocus alters the focus sequence"
      @findings: "map current tabindex assignments and focus management code;
                  simulate sequential focus navigation with and without shadow boundaries;
                  identify focus traps or unreachable elements"
      @evidence: "HTML Spec §6.6.3 (sequential focus navigation), §6.6.4 (focusable area),
                  DOM Spec §4.8 (delegatesFocus option), ebook-navigation.mjs focus handlers"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/06-focus-keyboard.spw" }
  }

  ^phase["Accessibility Tree and ARIA Mapping"]{
    ^task{
      @scope: "audit accessibility tree construction across shadow boundaries —
               determine whether shadow DOM introduces name computation failures or
               role mapping gaps for the spw component set"
      @findings: "for each component with ARIA attributes: verify that accessible name
                  computation (AccName §4) produces identical results with and without
                  shadow encapsulation; flag cross-boundary aria-labelledby references"
      @evidence: "AccName Spec §4 (name computation steps), ARIA §5.2.8 (role mapping),
                  PLAN.A §foundation phase 03 aria baseline output"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/07-a11y.spw" }
  }

  ^phase["Form Association and ElementInternals Review"]{
    ^task{
      @scope: "evaluate ElementInternals for form-associated custom elements —
               determine whether any spw components participate in form submission
               and whether ElementInternals would simplify or complicate that participation"
      @findings: "inventory form-participating components (if any); evaluate
                  ElementInternals.setFormValue / setValidity against current approach;
                  assess browser support coverage for form-associated custom elements"
      @evidence: "HTML Spec §4.13.6.1 (ElementInternals), §4.13.6.3 (form-associated),
                  Can I Use: form-associated custom elements"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/08-form-internals.spw" }
  }

  ^phase["Declarative Shadow DOM Feasibility"]{
    ^task{
      @scope: "evaluate declarative shadow DOM (<template shadowrootmode>) for SSR/hydration
               compatibility — lore.land currently serves static HTML via GitHub Pages;
               determine whether declarative shadow DOM enables progressive enhancement
               without requiring a server-side rendering pipeline"
      @findings: "test declarative shadow DOM parsing in static-file context;
                  measure hydration cost (time to interactive delta);
                  evaluate streaming HTML compatibility (relevant for future CDN serving)"
      @evidence: "HTML Spec §4.12.3 (template element shadowrootmode attribute),
                  Chrome M111 release notes (declarative shadow DOM shipping),
                  Web Components CG: declarative shadow DOM explainer"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/09-declarative-shadow-dom.spw" }
  }

  ^phase["Performance and Memory Audit"]{
    ^task{
      @scope: "measure the performance and memory cost of shadow DOM adoption —
               shadow root creation, style calculation with shadow boundaries,
               mutation observer cost across shadow trees"
      @findings: "benchmark: shadow root creation time per component, style recalculation
                  latency with N shadow boundaries, memory overhead per shadow root;
                  compare against current attribute-based scoping baseline"
      @evidence: "Chrome DevTools Performance panel measurements,
                  memory snapshots (heap snapshot diffing),
                  CSS containment spec §3 (layout/style/paint containment interaction)"
      @decision: classify_adopt_monitor_reject
    }
    %metrics: {
      shadow_root_creation_p95: "microseconds — comparative against createElement baseline"
      style_recalc_delta: "milliseconds with vs without shadow boundaries for 14-page set"
      memory_overhead_per_root: "bytes — measured via heap snapshot differential"
    }
    ={ "book/audits/shadow-dom/10-performance.spw" }
  }

  ^phase["Shadow DOM Test Strategy"]{
    ^task{
      @scope: "define the testing approach for shadow-DOM-encapsulated components —
               unit testing (querySelector boundary), integration testing (event flow),
               and visual regression testing (screenshot diffing across shadow boundaries)"
      @findings: "evaluate testing framework compatibility: does the current test setup
                  (if any) support shadow DOM queries? identify gaps in selector-based
                  testing (e.g., document.querySelector cannot pierce closed shadow roots)"
      @evidence: "Web Test Runner shadow DOM support, Playwright locator.shadowRoot(),
                  Testing Library within-shadow queries, current project test infrastructure"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/11-test-strategy.spw" }
  }

  ^phase["Refactor Blueprint"]{
    ^task{
      @scope: "produce a prioritized component refactor matrix — which components benefit
               most from shadow encapsulation, what is the migration order, and what are
               the mechanical steps for each migration tier"
      @findings: "rank components by: encapsulation benefit (from phase 02), event risk (from phase 05),
                  a11y risk (from phase 07), performance cost (from phase 10);
                  produce migration tiers: tier 1 (high benefit, low risk), tier 2 (moderate),
                  tier 3 (low benefit or high risk — defer)"
      @evidence: "synthesized from phases 01-11 findings; cross-referenced with
                  PLAN.A §foundation component dependency map"
      @decision: classify_adopt_monitor_reject
    }
    ={ "book/audits/shadow-dom/12-refactor-blueprint.spw" }
  }

  ^phase["Shadow DOM Master Report"]{
    ^task{
      @scope: "synthesize all shadow DOM track findings into a single adoption recommendation
               with acceptance criteria, risk register, and implementation timeline"
      @findings: "aggregate: adoption score (weighted sum across 12 facets), blocking issues,
                  prerequisite platform support requirements, estimated migration effort"
      @evidence: "all shadow DOM track artifacts (phases 01-12), chrome milestone track
                  findings relevant to shadow DOM (cross-reference from track 2)"
      @decision: "final recommendation: adopt | adopt-with-guardrails | monitor | reject —
                  with per-facet justification and dissenting considerations"
    }
    %metrics: {
      facets_recommending_adopt: "count out of 12"
      blocking_issues: "count — if > 0, recommendation cannot be 'adopt'"
      estimated_migration_effort: "component-days — informational"
    }
    ={ "book/audits/shadow-dom/13-master-report.spw" }
  }
}


^chrome_milestone_template{
  milestone_range: "M145..M94"
  phase_total: 52
  title_template: "Chrome M{milestone} Update Audit"
  emit_template: "book/audits/chrome-updates/M{milestone}.spw"

  ^task_protocol{
    @scope: "ingest release notes, highlights, and devtools changes for the milestone"
    @findings: "extract features with shadow DOM, custom element, CSS scoping, or
                event model relevance — classify by specification area"
    @evidence: "primary source: developer.chrome.com/release-notes/{milestone};
                secondary: chromestatus.com feature entries with linked specs"
    @decision: "per-feature relevance score: none | monitor | adopt | adopt-now"
    .note: "the 'adopt-now' score indicates a feature that is already shipping stable
            and directly addresses a gap identified in the shadow DOM track"
  }

  ^ingest_pipeline{
    .step[1]: "fetch release notes for M{milestone}"
    .step[2]: "fetch 'new in Chrome {milestone}' highlights (when published)"
    .step[3]: "fetch 'new in DevTools {milestone}' (when published)"
    .step[4]: "extract shadow-DOM-relevant deltas: new APIs, behavioral changes,
               deprecations, removals, origin trial promotions"
    .step[5]: "for each delta: record {feature_name, spec_section, support_status,
               shadow_dom_relevance, implementation_cost_estimate}"
    .step[6]: "score per-feature relevance for lore.land component model"
    .step[7]: "emit phase artifact"
  }

  scoring_scale: { none: allowed, monitor: allowed, adopt: allowed, adopt_now: allowed }
}

^phases["Chrome Milestone Exploration"]{
  .note: "52 phases — one per Chrome stable milestone from M94 (September 2021) through
          M145 (February 2026). Phases are grouped into epochs by significant platform
          changes; epoch annotations identify milestones with outsized shadow DOM relevance."

  ~<epoch["M94-M100: Foundation Era"]>{
    .note: "early baseline — custom elements v1 stable, declarative shadow DOM not yet shipped,
            CSS container queries in origin trial. These milestones establish the pre-modern
            baseline against which later improvements are measured."
