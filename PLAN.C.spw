^synthesis_and_governance{
  summary_emit: "book/audits/chrome-updates/summary-52.spw"
  risk_emit: "book/audits/chrome-updates/risk-register.spw"
  summary_columns: {
    feature: required
    first_appeared: required
    stable_support: required
    shadow_dom_relevance: required
    implementation_cost: required
    risk: required
    adoption_decision: required
  }
  adoption_buckets: { adopt_now: supported, adopt_with_guardrails: supported, monitor: supported, reject: supported }
  .note: "the synthesis artifact joins shadow DOM track findings with chrome milestone track data —
          features scored 'adopt-now' in the milestone track that address gaps identified in the
          shadow DOM track are prioritized in the final recommendation"
}

^acceptance_criteria{
  phase_total: equals_65
  shadow_track: equals_13
  chrome_track: equals_52
  emit_paths: deterministic_and_complete
  implementation_code: excluded
  .note: "Plan C is audit-only — no implementation code is produced;
          implementation decisions feed into PLAN.A and PLAN.D"
}

^assumptions{
  latest_updates_scope: latest_52_major_stable_milestones
  source_of_truth: official_chrome_release_channels
  output_mode: spw_artifacts
  .note: "milestone range M94-M145 covers September 2021 through February 2026 —
          this window captures the full lifecycle of modern shadow DOM features
          from origin trial through stable shipping"
}
