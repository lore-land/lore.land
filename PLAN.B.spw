#>plan_b
#:layer #!pragmatics

^meta{
  source: "PLAN.B.md"
  dialect: spw_native
  style: phase_block_titles
}

&plan_contracts{
  preserve_rollout_shape: true
  preserve_claim_interaction_behavior: true
  use_phase_blocks: true
}

^phase_packet_contract{
  required: { phase_goal: required, steps: required, verify: required }
  optional: { events: optional, api_delta: optional, outputs: optional }
}

?["plan_b_integrity_gate"]{
  require: phases_defined_in_blocks
  require: phase_total_4
  require: runtime_signal_mapping_explicit
  on_fail: emit_repair_packet
}

!probe{
  id: plan_b.phase_block_probe
  ask: ethos_plan_uses_titled_phase_blocks
}

^summary{
  intent: deepen_ethos_integration_across_home_chapter_custom_runtime
  source_of_truth: spw_claim_chain
  priority: diagnostics_first
  interaction_policy: keep_current_claim_handle_behavior
}

^current_gaps{
  claims_hydration: hardcoded_not_spw_canon
  status_model: single_string_overwrite
  signal_coverage: partial_runtime_signals_only
  claim_states: missing_untested_active_confirmed_refuted_model
  diagnostics_feed: missing_custom_runtime_cycle_feed
}

^phases["Ethos Integration Rollout"]{
  ^phase["Canon Claim Hydration"]{
    phase_goal: hydrate_claims_from_spw_canon_with_fallback
    module: book_scripts_modules_ethos_claims
    steps: {
      fetch: fetch_normalize_spw_source_claims_chapter_claims
      parse: parse_claim_chain_fields_claim_id_layer_hypothesis_measure_falsification_spec_impl_probe_status
      normalize: normalize_to_runtime_claim_shape
      metadata: attach_source_metadata_remote_or_fallback_reason
      fallback: fallback_to_local_constants_on_fetch_or_parse_failure
    }
    verify: {
      remote_success: remote_claims_parse_success_path
      fallback_fetch: fallback_fetch_failed_path
      fallback_parse: fallback_parse_failed_path
    }
  }

  ^phase["Ethos Diagnostics Engine"]{
    phase_goal: create_runtime_diagnostic_signal_model_and_claim_status_machine
    module: book_scripts_modules_ethos_diagnostics
    events: {
      load_stage: lore_load_stage
      selection: lore_spw_selection
      section_change: lore_ebook_section_change
      acoustics: lore_acoustics_profile
      preferences: lore_preference_change
      runtime_cycle: lore_spw_runtime_cycle
    }
    steps: {
      normalize: normalize_signal_packets
      buffer: maintain_ring_buffer_limit_24_default
      counters: maintain_per_claim_evidence_and_error_counters
      transitions: transition_status_untested_active_confirmed_refuted
      observability: emit_observability_events
    }
    api_delta: {
      ethos_diagnostic_event: lore_ethos_diagnostic
      claim_status_event: lore_ethos_claim_status
    }
    verify: {
      deterministic: deterministic_status_transitions
      refutation: refutation_path_on_error_cycle
      scope: session_scope_non_persistent_status
    }
  }

  ^phase["Integrate Into Ethos Panel"]{
    phase_goal: wire_hydration_and_diagnostics_into_panel_without_interaction_changes
    module: book_scripts_modules_spw_ethos
    steps: {
      hydration: async_claim_hydration_integration
      diagnostics: diagnostics_engine_attachment
      status: render_per_claim_status_and_evidence
      readout: render_compact_recent_signal_readout
      filtering: preserve_layer_filtering_and_setLayer_contract
      callsites: preserve_entrypoint_callsites
    }
    state_hooks: {
      panel: { source: data_ethos_source, mode: data_ethos_diagnostic_mode, last_signal: data_ethos_last_signal, signal_count: data_ethos_signal_count }
      claim: { status: data_claim_status, evidence: data_claim_evidence, errors: data_claim_errors }
    }
    verify: {
      click_behavior: click_behavior_regression_none
      parity: home_chapter_status_parity
      cleanup: destroy_cleans_listeners_and_state
    }
  }

  ^phase["Styling Docs and Hardening"]{
    phase_goal: ship_readable_status_visuals_and_update_spw_docs
    targets: {
      cards_css: book_styles_components_cards_css
      sections_css: book_styles_home_sections_css
      spw_index: spw_index
      spw_workspace: spw_workspace
      claims_schema: optional_claim_schema_enrichment
    }
    steps: {
      states: add_visual_states_untested_active_confirmed_refuted
      responsiveness: validate_mobile_and_wide_breakpoint_legibility
      schema: align_claim_schema_fields_with_claim_protocol
    }
    verify: {
      visuals: visual_regression_grid_stream_book_variants_clear
      docs_runtime: docs_and_runtime_contracts_in_sync
    }
  }
}

^public_api_additions{
  function: initSpwEthosIntegration
  options: { claimsUrl: normalizeSpwSource_claims_chapter_claims, diagnosticsLimit: 24, diagnosticMode: runtime }
  existing_contract: { setLayer: preserved, destroy: preserved }
  emitted_events: { ethos_diagnostic: lore_ethos_diagnostic, claim_status: lore_ethos_claim_status }
  local_types: { claim: EthosClaim, diagnostic: EthosDiagnostic, claim_status: EthosClaimStatus }
}

^test_matrix{
  hydration: { remote: remote_parse_ok, fetch_fallback: fetch_404_fallback, parse_fallback: parse_error_fallback }
  signal_mapping: { load: load_stage_pipeline_mapping, selection: selection_mapping, section: section_change_mapping, runtime_error: runtime_cycle_error_refutation }
  behavior_regression: { claim_handle: claim_handle_click_flow_unchanged, set_layer: setLayer_behavior_unchanged, destroy: destroy_cleanup_no_leaks }
  parity: { home: home_context, chapter: chapter_context }
  visuals: { status_chip: status_chip_legibility, diagnostics_readout: diagnostics_readout_legibility }
}

^rollout_strategy{
  milestone_a: claim_hydration_only_with_fallback
  milestone_b: diagnostics_engine_wired_minimal_ui
  milestone_c: panel_integration_home_and_chapter
  milestone_d: styling_docs_acceptance
}

^assumptions{
  scope: changes_local_to_lore_land_and_spw_canon
  workbench: no_submodule_changes_required_for_first_release
  hosting: spw_files_same_origin_when_available
  persistence: claim_status_session_scoped_default
}
